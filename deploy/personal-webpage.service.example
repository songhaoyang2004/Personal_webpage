[Unit]
Description=Personal webpage FastAPI (Gunicorn + Uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/personal-webpage/backend
Environment="PATH=/var/www/personal-webpage/backend/.venv/bin"
ExecStart=/var/www/personal-webpage/backend/.venv/bin/gunicorn main:app -k uvicorn.workers.UvicornWorker -b 127.0.0.1:8000 -w 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
